{
  "name": "@mailinlay/sdk",
  "version": "0.3.2",
  "description": "Embeddable IMAP/SMTP mailbox for React and Next.js admin panels",
  "private": true,
  "author": {
    "name": "Sebastian Pawelczyk",
    "url": "https://github.com/SebastianPRM"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianPRM/MailInlay.git"
  },
  "homepage": "https://github.com/SebastianPRM/MailInlay#readme",
  "keywords": [
    "email",
    "imap",
    "smtp",
    "react",
    "nextjs",
    "admin-panel"
  ],
  "type": "module",
  "files": [
    "dist",
    "src/styles/mailinlay.css",
    "README.md"
  ],
  "exports": {
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./styles.css": "./src/styles/mailinlay.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 4173",
    "build:sdk": "tsup",
    "build:demo": "next build",
    "build": "npm run build:sdk && npm run build:demo",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run typecheck && eslint .",
    "prepare": "npm run build:sdk"
  },
  "peerDependencies": {
    "react": ">=18.2",
    "react-dom": ">=18.2"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.8.0",
    "@tiptap/extension-underline": "^3.8.0",
    "@tiptap/react": "^3.8.0",
    "@tiptap/starter-kit": "^3.8.0",
    "imapflow": "^1.1.1",
    "lucide-react": "^1.16.0",
    "nodemailer": "^9.0.3",
    "postal-mime": "^2.4.3",
    "sanitize-html": "^2.17.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.0",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.1.0",
    "next": "16.2.6",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  },
  "license": "UNLICENSED"
}
